# Environment variables example for backend
# LOG_LEVEL: control the minimum log level produced by the application.
# Allowed values: info, warn, error
# - info  => prints info (log), warn and error
# - warn  => prints warn and error
# - error => prints only error

LOG_LEVEL=info
PORT=3000

# ─── Database ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=
DB_NAME=saas_multicloud
DB_TIMEZONE=America/Sao_Paulo

# ─── Authentication ──────────────────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=15m

# ─── Credentials Encryption ──────────────────────────────────────────────────
# 64-char hex string used as AES-256 key for cloud credential encryption
CREDENTIALS_ENCRYPTION_KEY=

# ─── Application URL ─────────────────────────────────────────────────────────
# Base URL used to build invite links in e-mails
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001

# ─── SMTP (e-mail) ───────────────────────────────────────────────────────────
# SMTP server settings for sending invite e-mails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
# Set SMTP_SECURE=true to use TLS (port 465), false for STARTTLS (port 587)
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# From address used in sent e-mails
SMTP_FROM=noreply@example.com

# ─── Redis (BullMQ — async job queue) ───────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=  # uncomment if your Redis requires authentication

# Governance worker concurrency (BullMQ)
# Default: 4 | Recommended range: 2-8 (hard cap: 16)
GOVERNANCE_WORKER_CONCURRENCY=4

# AWS workers concurrency (BullMQ)
# Default: 2 each | Recommended range: 1-4 (hard cap: 16)
AWS_ASSESSMENT_WORKER_CONCURRENCY=2
AWS_GENERAL_SYNC_WORKER_CONCURRENCY=2

# Azure workers concurrency (BullMQ)
# Default: 2 | Recommended range: 1-4 (hard cap: 16)
AZURE_ASSESSMENT_WORKER_CONCURRENCY=2

# ─── AWS (user) ───────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_USER_ARN=

# ─── Google (authentication) ───────────────────────────────────────────────
# Google always redirects to the backend callback first; the backend then
# sends the browser back to the frontend callback route.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# ─── GCP (cloud assessment) ──────────────────────────────────────────────────
# Service account JSON of the PLATFORM's own GCP SA used for impersonation.
# The SA must have the "Service Account Token Creator" role on each customer SA.
#
# Option 1 — base64-encoded (recommended for env files):
#   base64 -i platform-sa-key.json | tr -d '\n'
# Option 2 — raw JSON string (single line, with escaped quotes):
#   {"type":"service_account","project_id":"...","private_key_id":"..."}
#
# How to obtain:
#   1. In the GCP Console, go to IAM & Admin → Service Accounts.
#   2. Create (or select) the platform SA and go to Keys → Add Key → JSON.
#   3. Download the key file and encode it: base64 -i key.json | tr -d '\n'
GCP_SA_CREDENTIALS_JSON=

# GCP workers concurrency (BullMQ)
# Default: 2 | Recommended range: 1-4 (hard cap: 16)
GCP_GENERAL_SYNC_WORKER_CONCURRENCY=2

# ─── Stripe (billing) ────────────────────────────────────────────────────────
# Secret API key — use sk_test_... for development, sk_live_... for production
STRIPE_SECRET_KEY=sk_test_

# Webhook signing secret — obtained from the Stripe dashboard or CLI (whsec_...)
# Used to verify that webhook events are genuinely from Stripe
STRIPE_WEBHOOK_SECRET=whsec_

# Default Stripe Product ID assigned to every new organization on creation.
# The price used will be the product's default_price (if set and recurring),
# otherwise the first active recurring price found for that product.
# The product must have the following metadata:
#   max_cloud_accounts  — e.g. "5"
#   max_users           — e.g. "10"
#   modules             — comma-separated list, e.g. "assessment"
#                         use "*" for all modules, leave empty ("") for no modules
#                         valid module names are centralized in:
#                         src/common/modules/system-modules.ts
DEFAULT_STRIPE_PRODUCT_ID=prod_