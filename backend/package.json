{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "dev": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typeorm": "typeorm-ts-node-commonjs -d ./src/db/typeorm.migrations.config.ts",
    "migration:create": "npm run typeorm -- migration:create ./src/db/migrations/%npm_config_name%",
    "migration:generate": "npm run typeorm -- migration:generate ./src/db/migrations/%npm_config_name%",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:run:prod": "node ./node_modules/typeorm/cli.js migration:run -d ./dist/db/typeorm.migrations.config.js",
    "migration:revert": "npm run typeorm -- migration:revert",
    "migration:show": "npm run typeorm -- migration:show"
  },
  "dependencies": {
    "@aws-sdk/client-api-gateway": "^3.1005.0",
    "@aws-sdk/client-cloudfront": "^3.1004.0",
    "@aws-sdk/client-cloudtrail": "^3.1005.0",
    "@aws-sdk/client-cloudwatch": "^3.1005.0",
    "@aws-sdk/client-dynamodb": "^3.1005.0",
    "@aws-sdk/client-ec2": "^3.1001.0",
    "@aws-sdk/client-ecr": "^3.1005.0",
    "@aws-sdk/client-ecs": "^3.1003.0",
    "@aws-sdk/client-eks": "^3.1004.0",
    "@aws-sdk/client-elastic-load-balancing-v2": "^3.1003.0",
    "@aws-sdk/client-elasticache": "^3.1005.0",
    "@aws-sdk/client-guardduty": "^3.1005.0",
    "@aws-sdk/client-iam": "^3.1004.0",
    "@aws-sdk/client-kms": "^3.1005.0",
    "@aws-sdk/client-lambda": "^3.1005.0",
    "@aws-sdk/client-rds": "^3.1004.0",
    "@aws-sdk/client-route-53": "^3.1005.0",
    "@aws-sdk/client-s3": "^3.1004.0",
    "@aws-sdk/client-secrets-manager": "^3.1005.0",
    "@aws-sdk/client-sns": "^3.1005.0",
    "@aws-sdk/client-sqs": "^3.1005.0",
    "@aws-sdk/client-sts": "^3.1001.0",
    "@aws-sdk/client-wafv2": "^3.1005.0",
    "@aws-sdk/types": "^3.973.5",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^5.0.0",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/typeorm": "^11.0.0",
    "@types/nodemailer": "^7.0.11",
    "@types/uuid": "^10.0.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.70.4",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "nodemailer": "^8.0.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.19.0",
    "reflect-metadata": "^0.2.2",
